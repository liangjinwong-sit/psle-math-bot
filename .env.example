# ── LLM Provider ──────────────────────────────────────────────
# Choose which LLM to use: "gemini" (default), "openai", "groq", or "ollama"
# LLM_PROVIDER=gemini

# ── Google Gemini (default) ───────────────────────────────────
# Free API key: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# ── OpenAI (optional) ────────────────────────────────────────
# https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ── Groq (optional) ──────────────────────────────────────────
# Free API key: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ── Ollama (optional, no key needed) ─────────────────────────
# Install Ollama, then: ollama pull llama3.2:latest
# Set LLM_PROVIDER=ollama to use
